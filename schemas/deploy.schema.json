{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/BQN-UY/CI-CD/v2/schemas/deploy.schema.json",
  "title": "BQN-UY — .github/deploy.json",
  "description": "Config de deploy v2 para server apps. Reemplaza sistemas.json de v1 (descentralizado por repo). Ver docs/v2-hito2-deploy-spec.md §4.9.",
  "type": "object",
  "required": ["application_type", "environments"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Referencia al schema (permitido para habilitar validación en editores)."
    },
    "application_type": {
      "type": "string",
      "description": "Tipo de aplicación (stack + forma). Alinea con la taxonomía templates/<stack>-<tipo>/ y los reusable workflows <stack>-<tipo>-*.yml. Las libs no llevan deploy.json.",
      "enum": ["scala-api", "scala-vaadin", "scala-web", "python-api", "node-api"]
    },
    "environments": {
      "type": "object",
      "description": "Mapping de ambiente a su lista de instalaciones. Al menos un ambiente definido.",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "testing":    { "$ref": "#/$defs/environment" },
        "staging":    { "$ref": "#/$defs/environment" },
        "production": { "$ref": "#/$defs/environment" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "application_type": { "const": "scala-api" } }, "required": ["application_type"] },
      "then": { "$ref": "#/$defs/extensionMustBeJar" }
    },
    {
      "if": { "properties": { "application_type": { "const": "scala-vaadin" } }, "required": ["application_type"] },
      "then": { "$ref": "#/$defs/extensionMustBeWar" }
    }
  ],
  "$defs": {
    "extensionMustBeJar": {
      "properties": {
        "environments": {
          "properties": {
            "testing":    { "$ref": "#/$defs/allInstallationsJar" },
            "staging":    { "$ref": "#/$defs/allInstallationsJar" },
            "production": { "$ref": "#/$defs/allInstallationsJar" }
          }
        }
      }
    },
    "extensionMustBeWar": {
      "properties": {
        "environments": {
          "properties": {
            "testing":    { "$ref": "#/$defs/allInstallationsWar" },
            "staging":    { "$ref": "#/$defs/allInstallationsWar" },
            "production": { "$ref": "#/$defs/allInstallationsWar" }
          }
        }
      }
    },
    "allInstallationsJar": {
      "properties": {
        "installations": {
          "items": { "properties": { "artifact": { "properties": { "extension": { "const": "jar" } } } } }
        }
      }
    },
    "allInstallationsWar": {
      "properties": {
        "installations": {
          "items": { "properties": { "artifact": { "properties": { "extension": { "const": "war" } } } } }
        }
      }
    },
    "environment": {
      "type": "object",
      "required": ["installations"],
      "additionalProperties": false,
      "properties": {
        "installations": {
          "type": "array",
          "description": "Instalaciones que se deployan en este ambiente. Sin duplicados por 'name'.",
          "minItems": 1,
          "items": { "$ref": "#/$defs/installation" },
          "uniqueItemProperties": ["name"]
        }
      }
    },
    "installation": {
      "type": "object",
      "required": ["name", "portainer_endpoint", "portainer_container", "artifact"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Identificador único de la instalación dentro del ambiente. Usado para selección manual en workflow_dispatch.",
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "portainer_endpoint": {
          "type": "string",
          "description": "Nombre del endpoint Portainer (PublicURL). Se resuelve a ID por API al momento del deploy.",
          "minLength": 1
        },
        "portainer_container": {
          "type": "string",
          "description": "Nombre del container en el endpoint. Se resuelve a ID por API al momento del deploy.",
          "minLength": 1
        },
        "auto_deploy": {
          "type": "boolean",
          "description": "Si true, la instalación se incluye cuando el deploy se dispara sin selección manual de instalaciones. Default false.",
          "default": false
        },
        "artifact": {
          "type": "object",
          "required": ["deploy_path", "extension"],
          "additionalProperties": false,
          "properties": {
            "deploy_path": {
              "type": "string",
              "description": "Path absoluto donde copiar el artefacto (montado al container). Ej. /opt/webapps.",
              "pattern": "^/.+"
            },
            "extension": {
              "type": "string",
              "description": "Extensión del artefacto sin el punto.",
              "enum": ["war", "jar"]
            },
            "target_name": {
              "type": "string",
              "description": "Nombre con el que se renombra el archivo al copiarlo (sin extensión). Si se omite, se usa 'name' de la instalación.",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            }
          }
        }
      }
    }
  }
}
